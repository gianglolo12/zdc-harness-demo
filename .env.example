# ─── GitLab ────────────────────────────────────────────────────────────────────

# Personal or project access token with `api` scope
# Used by the GitLab client to create/update MRs and post comments
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Secret token configured in the GitLab webhook settings
# Sent by GitLab as the `x-gitlab-token` header; the harness rejects requests
# that do not match this value exactly
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Base URL of your GitLab instance (no trailing slash)
GITLAB_URL=https://gitlab.example.com

# ─── Redis ─────────────────────────────────────────────────────────────────────

# BullMQ job queue and state storage
# Format: redis[s]://[[username][:password]@][host][:port][/db-number]
REDIS_URL=redis://localhost:6379

# ─── Harness behaviour ─────────────────────────────────────────────────────────

# Dry-run mode: set to 1 to run Phase 1 (impact analysis + draft MR) only.
# Phase 2 (code generation) will NOT be triggered.
# Useful for validating agent output quality before enabling auto-implement.
# Default: 0 (live mode)
DRY_RUN=0

# Kill-switch: set to 1 to pause all workers immediately.
# Jobs remain in the queue and are held without processing until this is cleared.
# Default: 0 (running)
HARNESS_PAUSED=0
